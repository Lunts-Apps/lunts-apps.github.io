---
export interface Props {
  title: string;
  description: string;
  lang: string;
  canonical: string;
  ogImage?: string;
}
const { title, description, lang, canonical, ogImage } = Astro.props;
const langAttr = lang === 'en' ? 'en' : lang;
---

<!doctype html>
<html lang={langAttr}>
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/assets/bitsquid-favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="Bitsquid, Lunts, College Dating, Citas Universitarias, Chat Universitario, Blind Dates, Citas a Ciegas, Conexiones Genuinas, Mobile App, Dating App, University Dating, Estudiantes, App de Citas" />
    <meta name="author" content="Bitsquid Corp" />
    <meta name="robots" content="index, follow" />
    <meta name="language" content={lang === 'en' ? 'English' : lang === 'es' ? 'Spanish' : 'French'} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage || 'https://bit-squid.com/assets/bitsquid-banner.png'} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Bitsquid" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : lang === 'es' ? 'es_ES' : 'fr_FR'} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage || 'https://bit-squid.com/assets/bitsquid-banner.png'} />
    <meta property="twitter:creator" content="@bitsquidcorp" />
    <meta property="twitter:site" content="@bitsquidcorp" />
    
    <!-- Additional Meta Tags -->
    <meta name="theme-color" content="#9B5DE5" />
    <meta name="msapplication-TileColor" content="#9B5DE5" />
    <meta name="msapplication-config" content="/browserconfig.xml" />
    <meta name="format-detection" content="telephone=no" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical} />

    <!-- Permissions Policy -->
    <meta http-equiv="Permissions-Policy" content="unload=(self)" />
    
    <!-- Alternate Language Versions -->
    <link rel="alternate" hreflang="en" href="https://bit-squid.com/en" />
    <link rel="alternate" hreflang="es" href="https://bit-squid.com/es" />
    <link rel="alternate" hreflang="fr" href="https://bit-squid.com/fr" />
    <link rel="alternate" hreflang="x-default" href="https://bit-squid.com/" />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Bitsquid Corp",
      "alternateName": "Bitsquid",
      "url": "https://bit-squid.com/",
      "logo": "https://bit-squid.com/assets/bitsquid-favicon.svg",
      "description": "Bitsquid creates innovative mobile applications for users worldwide. Our goal is to develop unique digital experiences that connect, inspire, and provide real value.",
      "foundingDate": "2023",
      "founders": [
        {
          "@type": "Person",
          "name": "Bitsquid Team"
        }
      ],
      "sameAs": [
        "https://www.instagram.com/luntsapp",
        "https://www.facebook.com/lunts.app.9",
        "https://www.tiktok.com/@lunts.app",
        "https://www.youtube.com/@luntsapp3634"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "bitsquidcorp@gmail.com",
        "contactType": "Customer Support",
        "availableLanguage": ["English", "Spanish", "French"]
      },
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "Colombia"
      }
    }
    </script>
    
    <!-- App Links -->
    <link rel="manifest" href="/manifest.json" />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=League+Spartan:wght@100;200;300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        width: 100%;
        height: 100%;
      }

      body {
        font-family: 'League Spartan', sans-serif;
        background-color: #0B0C10;
        color: #F9F9F9;
        line-height: 1.6;
        overflow-x: hidden;
        width: 100%;
        min-height: 100vh;
        margin: 0;
        padding: 0;
      }

      #root {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .App {
        width: 100%;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      main {
        flex: 1;
        width: 100%;
      }

      a {
        text-decoration: none;
        color: inherit;
      }

      button {
        border: none;
        background: none;
        cursor: pointer;
        font-family: inherit;
      }

      ul {
        list-style: none;
        padding-left: 1.5rem;
      }

      ol {
        list-style: none;
      }

      ul li::before {
        content: "♦";
        color: #489B7D;
        font-weight: bold;
        display: inline-block;
        width: 1.2em;
        margin-left: -1.2em;
      }

      img {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
