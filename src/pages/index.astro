---
// Static redirect for GitHub Pages
const lang = 'en';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="/assets/bitsquid-favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <meta http-equiv="refresh" content={`0;url=/${lang}`} />
  <title>Bitsquid - Lunts</title>
  <link rel="canonical" href={`https://bit-squid.com/${lang}`} />
</head>
<body>
  <p>Redirecting to <a href={`/${lang}`}>{`/${lang}`}</a>...</p>
</body>
</html>